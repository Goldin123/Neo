{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtSettings": {
    "Secret": "your-super-secret-key-here-or-security-purposes",
    "Issuer": "NeoApi",
    "Audience": "NeoApiUsers",
    "ExpiryMinutes": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(local);Database=neo;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True;Connection Timeout=30"
  },

  "AllowedHosts": "*"
}
